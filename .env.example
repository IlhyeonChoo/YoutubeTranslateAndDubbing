# Default provider: Google Cloud Vertex AI.
DUBBING_AGENT_LLM_PROVIDER=vertexai
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# LLM quota safeguards. Set requests per minute to 0 to disable the rate limiter.
# Defaults in code: vertexai=12, google-genai=4.
DUBBING_AGENT_LLM_REQUESTS_PER_MINUTE=12
DUBBING_AGENT_LLM_RESOURCE_EXHAUSTED_RETRIES=8
DUBBING_AGENT_LLM_RESOURCE_EXHAUSTED_DELAY_SECONDS=60
DUBBING_AGENT_LLM_RESOURCE_EXHAUSTED_MAX_DELAY_SECONDS=300

# Optional: Google AI Studio / Gemini Developer API.
# Set DUBBING_AGENT_LLM_PROVIDER=google-genai to use this value.
GOOGLE_API_KEY=
